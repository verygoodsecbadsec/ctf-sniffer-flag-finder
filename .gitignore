# ──────────────────────────────────────────
# CTF Sniffer & Flag Finder – Git ignore
# ──────────────────────────────────────────

# Capture files (generated by the script)
*.pcap
*.pcapng

# Export files (if you export matches, you may want to ignore them)
# Remove or adjust these lines if you want to version-control your findings
*found.pcap
*extracted*

# Temporary / error files
*.tmp
tshark_error.tmp

# OS junk
.DS_Store
Thumbs.db

# Editor / IDE files
*.swp
*.swo
*~
.vscode/
.idea/

# Bash history / logs
*.log
.bash_history
